# Local env — never commit real values
.env

# Polygon API key (copy to shell: `export POLYGON_API_KEY=...`)
POLYGON_API_KEY=

# Alpha Vantage free key — https://www.alphavantage.co/support/#api-key (25 req/day)
ALPHA_VANTAGE_API_KEY=

# Optional: where `data/silver/...` is rooted (defaults to ./data)
# CRUCIBO_DATA_ROOT=

# Optional: stamp manifests if you inject git SHA manually in CI
# CRUCIBO_GIT_SHA=
